    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"menuItemId\": \"{{menuItemId}}\",\n      \"name\": \"Pho Bo\",\n      \"quantity\": 2,\n      \"unitPrice\": 50000\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Create order and publish order.created event."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('orderId', data.id);",
                  "}",
                  "",
                  "pm.test('orderId is stored', function () {",
                  "  pm.expect(pm.collectionVariables.get('orderId')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "{{orderId}}"
              ]
            },
            "description": "Get the created order. Status should move from PendingPayment to Paid after event processing."
          }
        }
      ]
